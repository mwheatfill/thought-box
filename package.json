{
	"name": "thoughtbox",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"start": "node .output/server/index.mjs",
		"preview": "vite preview",
		"check": "biome check src/",
		"check:fix": "biome check --write src/",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx src/server/db/seed.ts",
		"db:studio": "drizzle-kit studio",
		"email:preview": "email dev --dir src/emails",
		"prepare": "husky"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.68",
		"@ai-sdk/azure": "^1.3.0",
		"@ai-sdk/react": "^3.0.156",
		"@assistant-ui/react": "^0.12.24",
		"@assistant-ui/react-ai-sdk": "^1.3.18",
		"@azure/identity": "^4.6.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@microsoft/microsoft-graph-client": "^3.0.7",
		"@react-email/components": "^0.0.34",
		"@react-email/render": "^1.0.4",
		"@react-email/tailwind": "^1.0.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-form": "^1.12.0",
		"@tanstack/react-query": "^5.72.0",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/react-table": "^8.21.0",
		"@tanstack/router-plugin": "^1.132.0",
		"ai": "^6.0.154",
		"assistant-stream": "0.3.10",
		"canvas-confetti": "^1.9.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.44.0",
		"lucide-react": "^0.545.0",
		"motion": "^12.12.0",
		"next-themes": "^0.4.6",
		"postgres": "^3.4.5",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-day-picker": "^9.14.0",
		"react-dom": "^19.2.0",
		"recharts": "^3.8.0",
		"shadcn": "^4.2.0",
		"sonner": "^2.0.2",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/canvas-confetti": "^1.6.4",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.1.4",
		"dotenv": "^16.5.0",
		"drizzle-kit": "^0.31.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lint-staged": "^16.1.0",
		"react-email": "^4.0.7",
		"tsx": "^4.19.0",
		"typescript": "^5.7.2",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.0.5"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": "biome check --write --no-errors-on-unmatched"
	},
	"pnpm": {
		"overrides": {
			"assistant-stream": "0.3.10"
		},
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "lightningcss"]
	}
}
