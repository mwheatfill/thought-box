# Database
DATABASE_URL=postgresql://postgres:local@localhost:5432/thoughtbox

# Azure / Entra ID (App Service Easy Auth)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Microsoft Graph API
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# ThoughtBox shared mailbox for sending notifications
THOUGHTBOX_SHARED_MAILBOX=

# AI Provider: "anthropic" or "azure-openai"
AI_PROVIDER=anthropic

# Anthropic (when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Azure OpenAI (when AI_PROVIDER=azure-openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# Local development
# Set to a user's Entra Object ID to simulate Easy Auth locally
DEV_USER_ENTRA_ID=
